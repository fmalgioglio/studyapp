// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StudySourceType {
  BOOK
  NOTES
  SLIDES
  OTHER
}

enum SessionStatus {
  PLANNED
  DONE
  SKIPPED
}

enum AssessmentType {
  EXAM
  TEST
  ORAL
  SELF_STUDY
}

enum ExamStatus {
  ACTIVE
  POSTPONED
  COMPLETED
  CANCELLED
}

enum StudyTargetImportance {
  LOW
  MEDIUM
  HIGH
}

enum EducationLevel {
  HIGH_SCHOOL
  UNIVERSITY
  INDEPENDENT
}

enum SchoolProfile {
  LICEO
  TECHNICAL
  PROFESSIONAL
  UNIVERSITY
  SELF_STUDY
  OTHER
}

enum StudyMaterialType {
  TEXTBOOK
  NOTES
  HANDOUTS
  COURSE_LINK
  PERSONAL_FILE
  OPEN_RESOURCE
}

enum StudyMaterialOrigin {
  OPEN_VERIFIED
  OFFICIAL_SOURCE
  USER_LINK
  USER_UPLOAD
}

enum StudyMaterialVerificationLevel {
  VERIFIED
  OFFICIAL
  USER_PROVIDED
  DISCOVERED
}

model Student {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String?
  fullName     String?
  weeklyHours  Int            @default(10)
  educationLevel EducationLevel @default(INDEPENDENT)
  schoolProfile  SchoolProfile  @default(SELF_STUDY)
  subjectAffinity Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  subjects     Subject[]
  exams        Exam[]
  examPlanStates ExamPlanState[]
  examStudyLogs  ExamStudyLog[]
  studyMaterials StudyMaterial[]
  sources      StudySource[]
  studySessions StudySession[]
}

model Subject {
  id           String      @id @default(cuid())
  studentId    String
  name         String
  color        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  student      Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exams        Exam[]
  studyMaterials StudyMaterial[]
  sources      StudySource[]
  studySessions StudySession[]

  @@index([studentId])
  @@unique([studentId, name])
}

model Exam {
  id            String      @id @default(cuid())
  studentId     String
  subjectId     String
  title         String
  examDate      DateTime
  assessmentType AssessmentType @default(EXAM)
  status         ExamStatus     @default(ACTIVE)
  importance     StudyTargetImportance @default(MEDIUM)
  targetGrade   String?
  workloadReadiness String?
  materialType      String?
  workloadPayload   Json?
  completedAt   DateTime?
  rescheduledFromDate DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  planState     ExamPlanState?
  studyLogs     ExamStudyLog[]
  studyMaterials StudyMaterial[]

  @@index([studentId])
  @@index([subjectId])
  @@index([examDate])
  @@index([status])
}

model ExamPlanState {
  id                         String   @id @default(cuid())
  studentId                  String
  examId                     String   @unique
  intensityPreference        String?  @default("balanced")
  summaryPreferencePct       Int      @default(30)
  paceLocked                 Boolean  @default(false)
  lastRecommendationSnapshot Json?
  lastGeneratedAt            DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model ExamStudyLog {
  id             String   @id @default(cuid())
  studentId       String
  examId          String
  minutesSpent    Int
  pagesCompleted  Int      @default(0)
  topic           String?
  completedAt     DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([examId])
  @@index([completedAt])
}

model StudySource {
  id            String          @id @default(cuid())
  studentId     String
  subjectId     String
  title         String
  type          StudySourceType
  wordCount     Int             @default(0)
  tokenEstimate Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  student       Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  studySessions StudySession[]

  @@index([studentId])
  @@index([subjectId])
}

model StudyMaterial {
  id                String                         @id @default(cuid())
  studentId         String
  subjectId         String?
  examId            String?
  type              StudyMaterialType
  origin            StudyMaterialOrigin
  title             String
  url               String?
  fileKey           String?                        @unique
  fileName          String?
  fileMimeType      String?
  fileSizeBytes     Int?
  fileContent       Bytes?
  licenseHint       String?
  availabilityHint  String?
  verificationLevel StudyMaterialVerificationLevel @default(USER_PROVIDED)
  estimatedScopePages Int?
  notes             String?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  exam    Exam?    @relation(fields: [examId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([subjectId])
  @@index([examId])
  @@index([origin])
  @@index([verificationLevel])
}

model StudySession {
  id            String        @id @default(cuid())
  studentId     String
  subjectId     String
  sourceId      String?
  scheduledFor  DateTime
  durationMin   Int
  status        SessionStatus @default(PLANNED)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  source        StudySource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([subjectId])
  @@index([sourceId])
  @@index([scheduledFor])
}
