{
  "name": "studyapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-dev.ps1",
    "dev:next": "next dev --hostname 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-smoke.ps1",
