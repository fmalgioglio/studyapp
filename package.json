    "session:end": "powershell -ExecutionPolicy Bypass -File ./scripts/end-session.ps1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "figma-mcp-server": "^2.1.1",
